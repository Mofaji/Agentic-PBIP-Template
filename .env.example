# Copy this file to .env for local development. use this .env for python-dotenv to load environment variables. Do not commit .env with real credentials to source control.
# Never commit real credentials.

SERVER=<SQL_SERVER_HOST_OR_IP>
DATABASE=<SQL_DATABASE_NAME>
USERNAME=<SQL_USERNAME>
PASSWORD=<SQL_PASSWORD>
DRIVER=<ODBC_DRIVER_NAME>
